<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="002-insert-data" author="sayat">

        <insert tableName="courses">
            <column name="name" value="Java Developer"/>
            <column name="description" value="Comprehensive backend development course using Java and Spring Boot"/>
        </insert>

        <insert tableName="courses">
            <column name="name" value="Python Developer"/>
            <column name="description" value="Comprehensive software development course using Python"/>
        </insert>

        <insert tableName="chapters">
            <column name="name" value="Java Fundamentals"/>
            <column name="description" value="Core Java language concepts"/>
            <column name="order_number" valueNumeric="1"/>
            <column name="course_id" valueNumeric="1"/>
        </insert>

        <insert tableName="chapters">
            <column name="name" value="Object Oriented Programming"/>
            <column name="description" value="Classes, objects and inheritance"/>
            <column name="order_number" valueNumeric="2"/>
            <column name="course_id" valueNumeric="1"/>
        </insert>

        <insert tableName="lessons">
            <column name="name" value="Variables and Data Types"/>
            <column name="description" value="Introduction to Java variables"/>
            <column name="content"
                    value="Java supports primitive and reference data types. Variables are used to store information that can be processed during program execution."/>
            <column name="order_number" valueNumeric="1"/>
            <column name="chapter_id" valueNumeric="1"/>
        </insert>

        <insert tableName="lessons">
            <column name="name" value="Classes and Objects"/>
            <column name="description" value="Introduction to OOP"/>
            <column name="content"
                    value="Object-oriented programming is based on classes and objects. Classes describe behavior and state, while objects are instances of classes."/>
            <column name="order_number" valueNumeric="1"/>
            <column name="chapter_id" valueNumeric="2"/>
        </insert>

    </changeSet>

</databaseChangeLog>